<UserControl x:Class="Excalibur5.Views.Controls.SidebarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="56">

    <Border Width="62" CornerRadius="0,8,8,0"
            BorderThickness="0,0,1,0"
            BorderBrush="#1d4957">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#0c1e2a" Offset="0.0"/>
                <GradientStop Color="#112935" Offset="0.4"/>
                <GradientStop Color="#153342" Offset="1.0"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="16" ShadowDepth="4"
                              Direction="0" Opacity="0.6"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Markets button -->
            <Button Grid.Row="0"
                    Command="{Binding Markets.ToggleMarketsCommand}"
                    ToolTip="Markets"
                    Margin="8,12,8,0"
                    Width="40" Height="40"
                    Cursor="Hand"
                    FocusVisualStyle="{x:Null}">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <!-- Glow background -->
                            <Border x:Name="GlowBg"
                                    CornerRadius="10"
                                    Opacity="0">
                                <Border.Background>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#5500f0ff" Offset="0"/>
                                        <GradientStop Color="#0000f0ff" Offset="1"/>
                                    </RadialGradientBrush>
                                </Border.Background>
                            </Border>

                            <!-- Main body -->
                            <Border x:Name="MainBody"
                                    CornerRadius="10"
                                    BorderThickness="1"
                                    BorderBrush="#2a5568">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#1e465a" Offset="0.0"/>
                                        <GradientStop Color="#153342" Offset="0.5"/>
                                        <GradientStop Color="#112935" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="2"
                                                      Direction="270" Opacity="0.5"/>
                                </Border.Effect>

                                <Grid>
                                    <!-- Top highlight -->
                                    <Border CornerRadius="9,9,0,0" Height="6" VerticalAlignment="Top"
                                            Opacity="0.12" IsHitTestVisible="False">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="White" Offset="0"/>
                                                <GradientStop Color="Transparent" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>

                                    <!-- Chart icon (simple lines) -->
                                    <Canvas Width="20" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Line X1="0" Y1="14" X2="5" Y2="8" Stroke="#00f0ff" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        <Line X1="5" Y1="8" X2="10" Y2="11" Stroke="#00f0ff" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        <Line X1="10" Y1="11" X2="15" Y2="4" Stroke="#00f0ff" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        <Line X1="15" Y1="4" X2="20" Y2="6" Stroke="#00f0ff" StrokeThickness="1.5" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    </Canvas>
                                </Grid>
                            </Border>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="GlowBg"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.25"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="GlowBg"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.25"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="MainBody" Property="BorderBrush" Value="#00f0ff"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MainBody" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#112935" Offset="0.0"/>
                                            <GradientStop Color="#0c1e2a" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <DataTrigger Binding="{Binding Markets.IsMarketsVisible}" Value="True">
                                <Setter TargetName="GlowBg" Property="Opacity" Value="0.7"/>
                                <Setter TargetName="MainBody" Property="BorderBrush" Value="#00f0ff"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Label below button -->
            <TextBlock Grid.Row="0"
                       Text="Markets"
                       FontSize="9"
                       Foreground="#e0eef8"
                       HorizontalAlignment="Center"
                       Margin="0,68,0,0"/>

            <!-- Recover + Bot buttons -->
            <StackPanel Grid.Row="1" VerticalAlignment="Top" Margin="0,12,0,0">

                <!-- Recover button -->
                <Button Command="{Binding Recover.ToggleRecoverCommand}"
                        ToolTip="Recover (Martingale)"
                        Margin="8,0,8,0"
                        Width="40" Height="40"
                        Cursor="Hand"
                        FocusVisualStyle="{x:Null}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Border x:Name="GlowBg"
                                        CornerRadius="10"
                                        Opacity="0">
                                    <Border.Background>
                                        <RadialGradientBrush>
                                            <GradientStop Color="#5500f0ff" Offset="0"/>
                                            <GradientStop Color="#0000f0ff" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Border x:Name="MainBody"
                                        CornerRadius="10"
                                        BorderThickness="1"
                                        BorderBrush="#2a5568">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#1e465a" Offset="0.0"/>
                                            <GradientStop Color="#153342" Offset="0.5"/>
                                            <GradientStop Color="#112935" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="2"
                                                          Direction="270" Opacity="0.5"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Border CornerRadius="9,9,0,0" Height="6" VerticalAlignment="Top"
                                                Opacity="0.12" IsHitTestVisible="False">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="White" Offset="0"/>
                                                    <GradientStop Color="Transparent" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <!-- Recover icon (circular arrows) -->
                                        <Canvas Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Path Data="M 9,2 A 7,7 0 1 1 2,9" Stroke="#00f0ff" StrokeThickness="1.4" Fill="Transparent"/>
                                            <Path Data="M 9,2 L 7,0 M 9,2 L 11,0" Stroke="#00f0ff" StrokeThickness="1.3"/>
                                            <Path Data="M 9,16 A 7,7 0 1 1 16,9" Stroke="#00f0ff" StrokeThickness="1.4" Fill="Transparent"/>
                                            <Path Data="M 9,16 L 7,18 M 9,16 L 11,18" Stroke="#00f0ff" StrokeThickness="1.3"/>
                                        </Canvas>
                                    </Grid>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="GlowBg"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0.25"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="GlowBg"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0" Duration="0:0:0.25"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                    <Setter TargetName="MainBody" Property="BorderBrush" Value="#00f0ff"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="MainBody" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#112935" Offset="0.0"/>
                                                <GradientStop Color="#0c1e2a" Offset="1.0"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <DataTrigger Binding="{Binding Recover.IsRecoverVisible}" Value="True">
                                    <Setter TargetName="GlowBg" Property="Opacity" Value="0.7"/>
                                    <Setter TargetName="MainBody" Property="BorderBrush" Value="#00f0ff"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBlock Text="Recover"
                           FontSize="9"
                           Foreground="#e0eef8"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,12"/>

                <!-- Bot button -->
                <Button Command="{Binding Strategy.ToggleBotCommand}"
                        ToolTip="Bot (Estratégia Automatizada)"
                        Margin="8,0,8,0"
                        Width="40" Height="40"
                        Cursor="Hand"
                        FocusVisualStyle="{x:Null}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Border x:Name="GlowBg"
                                        CornerRadius="10"
                                        Opacity="0">
                                    <Border.Background>
                                        <RadialGradientBrush>
                                            <GradientStop Color="#5500f0ff" Offset="0"/>
                                            <GradientStop Color="#0000f0ff" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Border x:Name="MainBody"
                                        CornerRadius="10"
                                        BorderThickness="1"
                                        BorderBrush="#2a5568">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#1e465a" Offset="0.0"/>
                                            <GradientStop Color="#153342" Offset="0.5"/>
                                            <GradientStop Color="#112935" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="2"
                                                          Direction="270" Opacity="0.5"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Border CornerRadius="9,9,0,0" Height="6" VerticalAlignment="Top"
                                                Opacity="0.12" IsHitTestVisible="False">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="White" Offset="0"/>
                                                    <GradientStop Color="Transparent" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <!-- Bot icon (robot) -->
                                        <Canvas Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <!-- Antenna -->
                                            <Line X1="9" Y1="0" X2="9" Y2="3" Stroke="#00f0ff" StrokeThickness="1.2"/>
                                            <Ellipse Canvas.Left="7.5" Canvas.Top="0" Width="3" Height="3" Fill="#00f0ff"/>
                                            <!-- Head -->
                                            <Rectangle Canvas.Left="3" Canvas.Top="4" Width="12" Height="8"
                                                       Stroke="#00f0ff" StrokeThickness="1.3" RadiusX="2" RadiusY="2"/>
                                            <!-- Eyes -->
                                            <Ellipse Canvas.Left="5.5" Canvas.Top="6.5" Width="2.5" Height="2.5" Fill="#00f0ff"/>
                                            <Ellipse Canvas.Left="10" Canvas.Top="6.5" Width="2.5" Height="2.5" Fill="#00f0ff"/>
                                            <!-- Body -->
                                            <Rectangle Canvas.Left="5" Canvas.Top="13" Width="8" Height="4"
                                                       Stroke="#00f0ff" StrokeThickness="1.2" RadiusX="1" RadiusY="1"/>
                                        </Canvas>
                                    </Grid>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="GlowBg"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0.25"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="GlowBg"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0" Duration="0:0:0.25"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                    <Setter TargetName="MainBody" Property="BorderBrush" Value="#00f0ff"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="MainBody" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#112935" Offset="0.0"/>
                                                <GradientStop Color="#0c1e2a" Offset="1.0"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <DataTrigger Binding="{Binding Strategy.IsBotVisible}" Value="True">
                                    <Setter TargetName="GlowBg" Property="Opacity" Value="0.7"/>
                                    <Setter TargetName="MainBody" Property="BorderBrush" Value="#00f0ff"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBlock Text="Bot"
                           FontSize="9"
                           Foreground="#e0eef8"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <!-- Log button at bottom -->
            <StackPanel Grid.Row="2" Margin="0,0,0,12">
                <Button Command="{Binding Log.ToggleLogCommand}"
                        ToolTip="Log"
                        Margin="8,0,8,0"
                        Width="40" Height="40"
                        Cursor="Hand"
                        FocusVisualStyle="{x:Null}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Border x:Name="GlowBg"
                                        CornerRadius="10"
                                        Opacity="0">
                                    <Border.Background>
                                        <RadialGradientBrush>
                                            <GradientStop Color="#5500f0ff" Offset="0"/>
                                            <GradientStop Color="#0000f0ff" Offset="1"/>
                                        </RadialGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Border x:Name="MainBody"
                                        CornerRadius="10"
                                        BorderThickness="1"
                                        BorderBrush="#2a5568">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#1e465a" Offset="0.0"/>
                                            <GradientStop Color="#153342" Offset="0.5"/>
                                            <GradientStop Color="#112935" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="4" ShadowDepth="2"
                                                          Direction="270" Opacity="0.5"/>
                                    </Border.Effect>
                                    <Grid>
                                        <Border CornerRadius="9,9,0,0" Height="6" VerticalAlignment="Top"
                                                Opacity="0.12" IsHitTestVisible="False">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="White" Offset="0"/>
                                                    <GradientStop Color="Transparent" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>
                                        <!-- Log icon (terminal/document lines) -->
                                        <Canvas Width="18" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Line X1="0" Y1="2" X2="14" Y2="2" Stroke="#00f0ff" StrokeThickness="1.3" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            <Line X1="0" Y1="6" X2="11" Y2="6" Stroke="#00f0ff" StrokeThickness="1.3" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            <Line X1="0" Y1="10" X2="16" Y2="10" Stroke="#00f0ff" StrokeThickness="1.3" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            <Line X1="0" Y1="14" X2="9" Y2="14" Stroke="#00f0ff" StrokeThickness="1.3" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Grid>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="GlowBg"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0.25"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="GlowBg"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0" Duration="0:0:0.25"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                    <Setter TargetName="MainBody" Property="BorderBrush" Value="#00f0ff"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="MainBody" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#112935" Offset="0.0"/>
                                                <GradientStop Color="#0c1e2a" Offset="1.0"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <DataTrigger Binding="{Binding Log.IsLogVisible}" Value="True">
                                    <Setter TargetName="GlowBg" Property="Opacity" Value="0.7"/>
                                    <Setter TargetName="MainBody" Property="BorderBrush" Value="#00f0ff"/>
                                </DataTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <TextBlock Text="Log"
                           FontSize="9"
                           Foreground="#e0eef8"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
