<UserControl x:Class="Excalibur5.Views.Controls.StrategyPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="280">

    <Border Width="310" CornerRadius="6"
            BorderBrush="#1d4957" BorderThickness="1"
            Margin="0">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0c1e2a" Offset="0"/>
                <GradientStop Color="#07121a" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="24" ShadowDepth="6"
                              Direction="180" Opacity="0.7"/>
        </Border.Effect>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="12,10">

                <!-- Header -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <Canvas Width="16" Height="16" VerticalAlignment="Center" Margin="0,0,6,0">
                        <!-- Antenna -->
                        <Line X1="8" Y1="0" X2="8" Y2="2.5" Stroke="#00f0ff" StrokeThickness="1"/>
                        <Ellipse Canvas.Left="6.5" Canvas.Top="0" Width="3" Height="3" Fill="#00f0ff"/>
                        <!-- Head -->
                        <Rectangle Canvas.Left="2.5" Canvas.Top="3.5" Width="11" Height="7"
                                   Stroke="#00f0ff" StrokeThickness="1.2" RadiusX="1.5" RadiusY="1.5"/>
                        <!-- Eyes -->
                        <Ellipse Canvas.Left="5" Canvas.Top="5.5" Width="2" Height="2" Fill="#00f0ff"/>
                        <Ellipse Canvas.Left="9" Canvas.Top="5.5" Width="2" Height="2" Fill="#00f0ff"/>
                        <!-- Body -->
                        <Rectangle Canvas.Left="4.5" Canvas.Top="11.5" Width="7" Height="3.5"
                                   Stroke="#00f0ff" StrokeThickness="1" RadiusX="1" RadiusY="1"/>
                    </Canvas>
                    <TextBlock Text="Estratégia Automatizada"
                               Foreground="#00f0ff" FontSize="12"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Estratégia -->
                <TextBlock Text="Estratégia" Foreground="#90b5c9" FontSize="10" Margin="0,0,0,4"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <ComboBox Style="{StaticResource DerivComboBox}"
                              ItemsSource="{Binding StrategyModes}"
                              SelectedItem="{Binding StrategyMode, Mode=TwoWay}"
                              Width="120" Height="22"
                              FontSize="10"
                              Foreground="#00f0ff"
                              ToolTip="Modo de estratégia"/>
                </StackPanel>

                <!-- Amostra (only in Trend mode) -->
                <StackPanel Margin="0,0,0,10"
                            Visibility="{Binding IsTrendMode, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Amostra" Foreground="#90b5c9" FontSize="10" Margin="0,0,0,4"/>
                    <TextBox Style="{StaticResource DerivTextBox}"
                             Text="{Binding SampleSizeText, UpdateSourceTrigger=PropertyChanged}"
                             Height="28" Width="80" HorizontalAlignment="Left" MaxLength="3"
                             ToolTip="Quantidade de candles analisados para determinar a tendência (mín. 1)"/>
                </StackPanel>

                <!-- Direction (hidden in Trend mode) -->
                <StackPanel Visibility="{Binding IsTrendMode, Converter={StaticResource InverseBoolToVis}}">
                    <TextBlock Text="Direção" Foreground="#90b5c9" FontSize="10" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <RadioButton Content="Call" Tag="Call" GroupName="Direction"
                                     Click="Direction_Click"
                                     Foreground="#a3b8cc" FontSize="11" Margin="0,0,10,0" Cursor="Hand"/>
                        <RadioButton Content="Put" Tag="Put" GroupName="Direction"
                                     Click="Direction_Click"
                                     Foreground="#a3b8cc" FontSize="11" Margin="0,0,10,0" Cursor="Hand"/>
                        <RadioButton Content="Ambos" Tag="Ambos" GroupName="Direction"
                                     IsChecked="True" Click="Direction_Click"
                                     Foreground="#a3b8cc" FontSize="11" Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>

                <!-- Duration + Stake (side by side) -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Duração (min)" Foreground="#90b5c9" FontSize="10" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource DerivTextBox}"
                                 Text="{Binding DurationMinutes, UpdateSourceTrigger=PropertyChanged}"
                                 Height="28" MaxLength="4"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Stake (USD)" Foreground="#90b5c9" FontSize="10" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource DerivTextBox}"
                                 Text="{Binding StakeText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="28" MaxLength="10"/>
                    </StackPanel>
                </Grid>

                <!-- Take Profit + Stop Loss (side by side) -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Take Profit (USD)" Foreground="#90b5c9" FontSize="10" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource DerivTextBox}"
                                 Text="{Binding TakeProfitText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="28" MaxLength="10"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Stop Loss (USD)" Foreground="#90b5c9" FontSize="10" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource DerivTextBox}"
                                 Text="{Binding StopLossText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="28" MaxLength="10"/>
                    </StackPanel>
                </Grid>

                <!-- Max Contracts + Recover (side by side) -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Máx. contratos" Foreground="#90b5c9" FontSize="10" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource DerivTextBox}"
                                 Text="{Binding MaxContractsText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="28" MaxLength="2"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Recover" Foreground="#90b5c9" FontSize="10" Margin="0,0,0,4"/>
                        <ComboBox Style="{StaticResource DerivComboBox}"
                                  ItemsSource="{Binding RecoverModes}"
                                  SelectedItem="{Binding RecoverMode, Mode=TwoWay}"
                                  Height="28"
                                  FontSize="11"
                                  Foreground="#00f0ff"
                                  ToolTip="Modo de recuperação (Martingale)"/>
                    </StackPanel>
                </Grid>

                <!-- Separator -->
                <Border Height="1" Background="#1d4957" Margin="0,0,0,10"
                        Visibility="{Binding IsTrendMode, Converter={StaticResource InverseBoolToVis}}"/>

                <!-- Indicators (hidden in Trend mode) -->
                <StackPanel Visibility="{Binding IsTrendMode, Converter={StaticResource InverseBoolToVis}}">
                    <TextBlock Text="Indicadores" Foreground="#90b5c9" FontSize="10" Margin="0,0,0,6"/>
                    <CheckBox Content="EMA 9/21 (cruzamento)"
                              IsChecked="{Binding EnableEma}"
                              Foreground="#a3b8cc" FontSize="11" Margin="0,0,0,4" Cursor="Hand"/>
                    <CheckBox Content="RSI (14)"
                              IsChecked="{Binding EnableRsi}"
                              Foreground="#a3b8cc" FontSize="11" Margin="0,0,0,4" Cursor="Hand"/>
                    <CheckBox Content="Suporte/Resistência"
                              IsChecked="{Binding EnableSupportResistance}"
                              Foreground="#a3b8cc" FontSize="11" Margin="0,0,0,4" Cursor="Hand"/>
                    <CheckBox Content="MACD (12/26/9)"
                              IsChecked="{Binding EnableMacd}"
                              Foreground="#a3b8cc" FontSize="11" Margin="0,0,0,4" Cursor="Hand"/>
                    <CheckBox Content="Bollinger Bands (20,2)"
                              IsChecked="{Binding EnableBollinger}"
                              Foreground="#a3b8cc" FontSize="11" Margin="0,0,0,4" Cursor="Hand"/>
                    <CheckBox Content="Padrões de Candles"
                              IsChecked="{Binding EnableCandlePattern}"
                              Foreground="#a3b8cc" FontSize="11" Margin="0,0,0,4" Cursor="Hand"/>
                    <CheckBox Content="Momentum (ROC)"
                              IsChecked="{Binding EnableMomentum}"
                              Foreground="#a3b8cc" FontSize="11" Margin="0,0,0,10" Cursor="Hand"/>

                    <!-- Confidence -->
                    <TextBlock Text="Confiança mínima" Foreground="#90b5c9" FontSize="10" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Slider Width="160"
                                Style="{StaticResource ConfidenceSliderStyle}"
                                Value="{Binding ConfidenceThreshold}"
                                VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ConfidenceThreshold, StringFormat=P0}"
                                   Foreground="#e0eef8" FontSize="11"
                                   FontFamily="Consolas" Margin="8,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Trailing Stop -->
                    <CheckBox Content="Trailing Stop (TP 70%→BE, 90%→50%)"
                              IsChecked="{Binding EnableTrailingStop}"
                              Foreground="#a3b8cc" FontSize="11" Margin="0,0,0,14" Cursor="Hand"/>
                </StackPanel>

                <!-- Separator -->
                <Border Height="1" Background="#1d4957" Margin="0,0,0,10"/>

                <!-- Status -->
                <TextBlock Text="Status" Foreground="#90b5c9" FontSize="10" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="#4a6a7a"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Fill" Value="#34c759"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                        <Setter Property="Fill" Value="#f0c040"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Foreground="#e0eef8" FontSize="11" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Inativo"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Text" Value="Ativo"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                        <Setter Property="Text" Value="Pausado"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <TextBlock Text="{Binding CurrentSignalText}"
                           Foreground="#00e8c8" FontSize="11"
                           FontFamily="Consolas" Margin="0,4,0,4"/>
                <TextBlock Text="{Binding StatsText}"
                           Foreground="#e0eef8" FontSize="10"
                           FontFamily="Consolas" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding LastTradeText}"
                           Foreground="#f0c040" FontSize="10"
                           FontFamily="Consolas" Margin="0,0,0,14"
                           TextWrapping="Wrap"/>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Command="{Binding StartCommand}"
                            Style="{StaticResource DerivCallButtonStyle}"
                            Width="70" Margin="0,0,6,0"
                            IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBool}}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="M0,0 L8,5 L0,10 Z" Fill="White" Width="8" Height="10"
                                  Stretch="Uniform" Margin="0,0,4,0"/>
                            <TextBlock Text="Iniciar" Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding PauseCommand}"
                            Style="{StaticResource DerivToggleButtonStyle}"
                            Width="70" Margin="0,0,6,0"
                            IsEnabled="{Binding IsRunning}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Canvas Width="10" Height="11" Margin="0,0,4,0">
                                <Rectangle Canvas.Left="0" Width="3.5" Height="11" RadiusX="1" RadiusY="1" Fill="White"/>
                                <Rectangle Canvas.Left="5.5" Width="3.5" Height="11" RadiusX="1" RadiusY="1" Fill="White"/>
                            </Canvas>
                            <TextBlock Text="Pausar" Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding StopCommand}"
                            Style="{StaticResource DerivPutButtonStyle}"
                            Width="70"
                            IsEnabled="{Binding IsRunning}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Rectangle Width="10" Height="10" RadiusX="2" RadiusY="2" Fill="White" Margin="0,0,4,0"/>
                            <TextBlock Text="Parar" Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
