<UserControl x:Class="Excalibur5.Views.Controls.ContractPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:Excalibur5.Views.Controls"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="900">

    <Border CornerRadius="6"
            BorderBrush="#1d4957" BorderThickness="1"
            Margin="0,4,0,0">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0c1e2a" Offset="0"/>
                <GradientStop Color="#07121a" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid Margin="12,8,12,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header: tab -->
            <Border Grid.Row="0" Margin="0,0,0,8">
                <StackPanel Orientation="Horizontal">
                    <!-- Call / Put tab (default) -->
                    <Border CornerRadius="4"
                            BorderBrush="#00f0ff" BorderThickness="1"
                            Padding="10,3">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.Recover.IsRecoverVisible, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DataContext.Strategy.IsBotVisible, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                <GradientStop Color="#0f2030" Offset="0"/>
                                <GradientStop Color="#1a4a5e" Offset="0.85"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="Call / Put"
                                   Foreground="#00f0ff"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <!-- Recover tab (when active) -->
                    <Border CornerRadius="4"
                            BorderBrush="#00f0ff" BorderThickness="1"
                            Padding="10,3">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.Recover.IsRecoverVisible, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                <GradientStop Color="#0f2030" Offset="0"/>
                                <GradientStop Color="#1a4a5e" Offset="0.85"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="{Binding DataContext.Recover.SelectedMode, RelativeSource={RelativeSource AncestorType=Window}, StringFormat='Recover — {0}'}"
                                   Foreground="#00f0ff"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>
                    </Border>
                    <!-- Bot tab (when active) -->
                    <Border CornerRadius="4"
                            BorderBrush="#00f0ff" BorderThickness="1"
                            Padding="10,3">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.Strategy.IsBotVisible, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                <GradientStop Color="#0f2030" Offset="0"/>
                                <GradientStop Color="#1a4a5e" Offset="0.85"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="Estratégia Automatizada"
                                   Foreground="#00f0ff"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Content: 3 columns -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT COLUMN: Mode toggle + Duration/EndTime + Strike + Stake (hidden when Recover active) -->
                <StackPanel Grid.Column="0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.Recover.IsRecoverVisible, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DataContext.Strategy.IsBotVisible, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- Mode toggle: Duração / Hora de Término -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <RadioButton x:Name="RbDuration" GroupName="ExpiryMode"
                                     IsChecked="{Binding UseDuration, Mode=TwoWay}"
                                     Content="Duração" Foreground="#a3b8cc" FontSize="11"
                                     Margin="0,0,14,0" Cursor="Hand"
                                     ToolTip="Definir duração do contrato"/>
                        <RadioButton x:Name="RbEndTime" GroupName="ExpiryMode"
                                     IsChecked="{Binding UseEndTime, Mode=OneWay}"
                                     Click="EndTimeMode_Click"
                                     Content="Hora de Término" Foreground="#a3b8cc" FontSize="11"
                                     Cursor="Hand"
                                     ToolTip="Escolher data/hora de expiração (GMT)"/>
                    </StackPanel>

                    <!-- DURATION MODE -->
                    <StackPanel Visibility="{Binding UseDuration, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Duração" Foreground="#90b5c9" FontSize="10" Margin="0,0,0,4"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <RadioButton x:Name="RbMinutes" GroupName="DurationUnit"
                                         IsChecked="True" Click="DurationUnit_Click" Tag="Minutes"
                                         Content="Min" Foreground="#a3b8cc" FontSize="11"
                                         Margin="0,0,10,0" Cursor="Hand"
                                         ToolTip="Minutos"/>
                            <RadioButton x:Name="RbHours" GroupName="DurationUnit"
                                         Click="DurationUnit_Click" Tag="Hours"
                                         Content="Hrs" Foreground="#a3b8cc" FontSize="11"
                                         Margin="0,0,10,0" Cursor="Hand"
                                         ToolTip="Horas"/>
                            <RadioButton x:Name="RbDays" GroupName="DurationUnit"
                                         Click="DurationUnit_Click" Tag="Days"
                                         Content="Dias" Foreground="#a3b8cc" FontSize="11"
                                         Cursor="Hand"
                                         ToolTip="Dias"/>
                        </StackPanel>

                        <TextBox Style="{StaticResource DerivTextBox}"
                                 Text="{Binding DurationText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="30" Width="120"
                                 HorizontalAlignment="Left"
                                 MaxLength="4"
                                 PreviewTextInput="DurationTextBox_PreviewTextInput"
                                 ToolTip="Tempo até o contrato expirar"/>
                        <TextBlock Text="{Binding DurationRange}"
                                   Foreground="#6090a8" FontSize="9"
                                   Margin="0,3,0,0"/>
                    </StackPanel>

                    <!-- END TIME MODE -->
                    <StackPanel Visibility="{Binding UseDuration, Converter={StaticResource InverseBoolToVis}}">
                        <TextBlock Text="Data (GMT)" Foreground="#90b5c9" FontSize="10" Margin="0,0,0,4"/>
                        <DatePicker x:Name="DpEndDate"
                                    Style="{StaticResource DerivDatePicker}"
                                    SelectedDate="{Binding SelectedEndDate, Mode=TwoWay}"
                                    DisplayDateStart="{Binding MinEndDate, Mode=OneWay}"
                                    DisplayDateEnd="{Binding MaxEndDate, Mode=OneWay}"
                                    CalendarOpened="DpEndDate_CalendarOpened"
                                    ToolTip="Data de expiração (GMT)">
                            <DatePicker.Resources>
                                <DataTemplate x:Key="DayTitleTemplate">
                                    <TextBlock Text="{Binding}"
                                               Foreground="#00f0ff"
                                               FontSize="10"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Margin="0,4,0,2"/>
                                </DataTemplate>
                            </DatePicker.Resources>
                        </DatePicker>
                    </StackPanel>

                    <!-- Expiry -->
                    <TextBlock Text="Prazo de validade:" Foreground="#90b5c9" FontSize="10" Margin="0,10,0,2"/>
                    <TextBlock Text="{Binding ExpiryDisplay}"
                               Foreground="#e0eef8" FontSize="11"
                               FontFamily="Consolas"/>

                    <!-- Strike price -->
                    <TextBlock Text="Preço de exercício:" Foreground="#90b5c9" FontSize="10" Margin="0,10,0,2"/>
                    <!-- Barrier ComboBox (both modes) -->
                    <ComboBox x:Name="CbBarrier"
                              Style="{StaticResource DerivComboBox}"
                              ItemsSource="{Binding AvailableBarrierDisplays}"
                              SelectedItem="{Binding SelectedBarrierDisplay, Mode=TwoWay}"
                              ToolTip="Preço de exercício (barreira relativa ao spot)"/>
                    <TextBlock Text="{Binding AbsoluteStrikeDisplay, StringFormat='Strike: {0}'}"
                               Foreground="#e0eef8" FontSize="10"
                               FontFamily="Consolas"
                               Margin="0,3,0,0"
                               ToolTip="Preço absoluto do strike (spot + offset)"/>

                    <!-- Stake input -->
                    <TextBlock Text="Entrada (Stake):" Foreground="#90b5c9" FontSize="10" Margin="0,10,0,4"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox Style="{StaticResource DerivTextBox}"
                                 Text="{Binding StakeText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="30" Width="120"
                                 MaxLength="10"
                                 PreviewTextInput="StakeTextBox_PreviewTextInput"
                                 ToolTip="Valor da entrada em USD (máx. 2 casas decimais)"/>
                        <StackPanel Margin="8,0,0,0">
                            <TextBlock Text="Recover" Foreground="#90b5c9" FontSize="9" Margin="0,0,0,2"/>
                            <ComboBox Style="{StaticResource DerivComboBox}"
                                      ItemsSource="{Binding RecoverModes}"
                                      SelectedItem="{Binding RecoverMode, Mode=TwoWay}"
                                      Width="90" Height="24"
                                      FontSize="10"
                                      Foreground="#00f0ff"
                                      ToolTip="Modo de recuperação (Martingale)"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="{Binding StakeRange}"
                               Foreground="#6090a8" FontSize="9"
                               Margin="0,3,0,0"/>
                </StackPanel>

                <!-- RIGHT COLUMN: Payout + Buttons (hidden when Recover active) -->
                <StackPanel Grid.Column="2">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.Recover.IsRecoverVisible, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding DataContext.Strategy.IsBotVisible, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- Payout per point (shared) -->
                    <TextBlock Text="Pagamento por ponto:" Foreground="#90b5c9" FontSize="10" Margin="0,0,0,2"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding CallPayoutPerPoint, StringFormat=F6}"
                                   Foreground="#00e8c8" FontSize="14"
                                   FontFamily="Consolas" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <Border Margin="6,0,0,0" Padding="2"
                                CornerRadius="8" Background="#1a3a4a"
                                VerticalAlignment="Center" Cursor="Help">
                            <Border.ToolTip>
                                <ToolTip MaxWidth="250">
                                    <TextBlock TextWrapping="Wrap"
                                               Text="O pagamento no vencimento é igual ao pagamento por ponto multiplicado pela diferença entre o preço final e o preço de exercício."/>
                                </ToolTip>
                            </Border.ToolTip>
                            <TextBlock Text="?" Foreground="#00f0ff" FontSize="9"
                                       FontWeight="Bold" HorizontalAlignment="Center"
                                       Width="12" TextAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- CALL block -->
                    <Border CornerRadius="5" BorderBrush="#2a5a3a" BorderThickness="1"
                            Margin="0,10,0,0" Padding="8,6"
                            HorizontalAlignment="Left" Width="140">
                        <Border.Background>
                            <SolidColorBrush Color="#0d2818" Opacity="0.6"/>
                        </Border.Background>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Preço:" Foreground="#90b5c9" FontSize="10" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CallAskPrice, StringFormat=F2}"
                                           Foreground="#f3fbff" FontSize="12"
                                           FontFamily="Consolas" FontWeight="Bold"
                                           Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Payout:" Foreground="#90b5c9" FontSize="10" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CallPayout, StringFormat=F2}"
                                           Foreground="#34c759" FontSize="12"
                                           FontFamily="Consolas" FontWeight="Bold"
                                           Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button x:Name="BtnCall" Click="CallButton_Click"
                                    Style="{StaticResource DerivCallButtonStyle}"
                                    IsEnabled="{Binding IsBuying, Converter={StaticResource InverseBool}}"
                                    Content="Comprar Call" Width="120"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- PUT block -->
                    <Border CornerRadius="5" BorderBrush="#5a2a2a" BorderThickness="1"
                            Margin="0,8,0,0" Padding="8,6"
                            HorizontalAlignment="Left" Width="140">
                        <Border.Background>
                            <SolidColorBrush Color="#280d0d" Opacity="0.6"/>
                        </Border.Background>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="Preço:" Foreground="#90b5c9" FontSize="10" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding PutAskPrice, StringFormat=F2}"
                                           Foreground="#f3fbff" FontSize="12"
                                           FontFamily="Consolas" FontWeight="Bold"
                                           Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <TextBlock Text="Payout:" Foreground="#90b5c9" FontSize="10" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding PutPayout, StringFormat=F2}"
                                           Foreground="#FF6B6B" FontSize="12"
                                           FontFamily="Consolas" FontWeight="Bold"
                                           Margin="6,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Button x:Name="BtnPut" Click="PutButton_Click"
                                    Style="{StaticResource DerivPutButtonStyle}"
                                    IsEnabled="{Binding IsBuying, Converter={StaticResource InverseBool}}"
                                    Content="Comprar Put" Width="120"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- BOT PANEL (visible when Bot active, spans cols 0-4) -->
                <ScrollViewer Grid.Column="0" Grid.ColumnSpan="3"
                              VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                              DataContext="{Binding DataContext.Strategy, RelativeSource={RelativeSource AncestorType=Window}}">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBotVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <StackPanel Margin="4,0,0,0">
                        <!-- Duração / Hora de Término toggle -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <RadioButton GroupName="BotExpiryMode"
                                         IsChecked="{Binding UseDuration, Mode=TwoWay}"
                                         Content="Duração" Foreground="#a3b8cc" FontSize="11"
                                         Margin="0,0,14,0" Cursor="Hand"
                                         ToolTip="Definir duração do contrato"/>
                            <RadioButton GroupName="BotExpiryMode"
                                         IsChecked="{Binding UseEndTime, Mode=OneWay}"
                                         Click="BotEndTimeMode_Click"
                                         Content="Hora de Término" Foreground="#a3b8cc" FontSize="11"
                                         Cursor="Hand"
                                         ToolTip="Escolher data/hora de expiração (GMT)"/>
                            <ComboBox Style="{StaticResource DerivComboBox}"
                                      ItemsSource="{Binding StrategyModes}"
                                      SelectedItem="{Binding StrategyMode, Mode=TwoWay}"
                                      Width="90" Height="22"
                                      FontSize="10" Margin="14,0,0,0"
                                      Foreground="#00f0ff"
                                      ToolTip="Modo de estratégia"/>
                        </StackPanel>

                        <!-- DURATION MODE -->
                        <StackPanel Visibility="{Binding UseDuration, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Duração" Foreground="#90b5c9" FontSize="10" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <RadioButton GroupName="BotDurationUnit" IsChecked="True"
                                             Click="BotDurationUnit_Click" Tag="Minutes"
                                             Content="Min" Foreground="#a3b8cc" FontSize="11"
                                             Margin="0,0,10,0" Cursor="Hand" ToolTip="Minutos"/>
                                <RadioButton GroupName="BotDurationUnit"
                                             Click="BotDurationUnit_Click" Tag="Hours"
                                             Content="Hrs" Foreground="#a3b8cc" FontSize="11"
                                             Margin="0,0,10,0" Cursor="Hand" ToolTip="Horas"/>
                                <RadioButton GroupName="BotDurationUnit"
                                             Click="BotDurationUnit_Click" Tag="Days"
                                             Content="Dias" Foreground="#a3b8cc" FontSize="11"
                                             Cursor="Hand" ToolTip="Dias"/>
                            </StackPanel>
                            <TextBox Style="{StaticResource DerivTextBox}"
                                     Text="{Binding DurationText, UpdateSourceTrigger=PropertyChanged}"
                                     Height="30" Width="120" HorizontalAlignment="Left" MaxLength="4"
                                     PreviewTextInput="BotDurationTextBox_PreviewTextInput"
                                     ToolTip="Tempo até o contrato expirar"/>
                            <TextBlock Text="{Binding DurationRange}" Foreground="#6090a8" FontSize="9" Margin="0,3,0,0"/>
                        </StackPanel>

                        <!-- END TIME MODE -->
                        <StackPanel Visibility="{Binding UseDuration, Converter={StaticResource InverseBoolToVis}}">
                            <TextBlock Text="Data (GMT)" Foreground="#90b5c9" FontSize="10" Margin="0,0,0,4"/>
                            <DatePicker Style="{StaticResource DerivDatePicker}"
                                        SelectedDate="{Binding SelectedEndDate, Mode=TwoWay}"
                                        ToolTip="Data de expiração (GMT)"/>
                        </StackPanel>

                        <!-- Prazo de validade -->
                        <TextBlock Text="Prazo de validade:" Foreground="#90b5c9" FontSize="10" Margin="0,10,0,2"/>
                        <TextBlock Text="{Binding ExpiryDisplay}" Foreground="#e0eef8" FontSize="11" FontFamily="Consolas"/>

                        <!-- Preço de exercício -->
                        <TextBlock Text="Preço de exercício:" Foreground="#90b5c9" FontSize="10" Margin="0,10,0,2"/>
                        <ComboBox Style="{StaticResource DerivComboBox}"
                                  ItemsSource="{Binding AvailableBarrierDisplays}"
                                  SelectedItem="{Binding SelectedBarrierDisplay, Mode=TwoWay}"
                                  ToolTip="Preço de exercício (barreira relativa ao spot)"/>

                        <!-- Pagamento por ponto -->
                        <TextBlock Text="Pagamento por ponto:" Foreground="#90b5c9" FontSize="10" Margin="0,10,0,2"/>
                        <TextBlock Text="{Binding PayoutPerPointDisplay}" Foreground="#00e8c8" FontSize="14"
                                   FontFamily="Consolas" FontWeight="Bold"/>

                        <!-- Separator -->
                        <Border Height="1" Background="#1d4957" Margin="0,10,0,10"/>

                        <!-- Amostra (only in Trend mode) -->
                        <StackPanel Margin="0,0,0,10"
                                    Visibility="{Binding IsTrendMode, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Amostra" Foreground="#90b5c9" FontSize="10" Margin="0,0,0,4"/>
                            <TextBox Style="{StaticResource DerivTextBox}"
                                     Text="{Binding SampleSizeText, UpdateSourceTrigger=PropertyChanged}"
                                     Height="28" Width="80" HorizontalAlignment="Left" MaxLength="3"
                                     ToolTip="Quantidade de candles analisados para determinar a tendência (mín. 1)"/>
                        </StackPanel>

                        <!-- Direction (hidden in Trend mode) -->
                        <StackPanel Visibility="{Binding IsTrendMode, Converter={StaticResource InverseBoolToVis}}">
                            <TextBlock Text="Direção" Foreground="#90b5c9" FontSize="10" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <RadioButton Content="Call" Tag="Call" GroupName="BotDirection"
                                             Click="BotDirection_Click"
                                             Foreground="#a3b8cc" FontSize="11" Margin="0,0,10,0" Cursor="Hand"
                                             ToolTip="Apenas operações Call (alta)"/>
                                <RadioButton Content="Put" Tag="Put" GroupName="BotDirection"
                                             Click="BotDirection_Click"
                                             Foreground="#a3b8cc" FontSize="11" Margin="0,0,10,0" Cursor="Hand"
                                             ToolTip="Apenas operações Put (baixa)"/>
                                <RadioButton Content="Ambos" Tag="Ambos" GroupName="BotDirection"
                                             IsChecked="True" Click="BotDirection_Click"
                                             Foreground="#a3b8cc" FontSize="11" Cursor="Hand"
                                             ToolTip="Operar em ambas as direções"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Stake + TP/SL + Max -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Stake (USD)" Foreground="#90b5c9" FontSize="10" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource DerivTextBox}"
                                         Text="{Binding StakeText, UpdateSourceTrigger=PropertyChanged}"
                                         Height="28" Width="80" MaxLength="10"
                                         ToolTip="Valor da entrada em USD"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="TP (USD)" Foreground="#90b5c9" FontSize="10" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource DerivTextBox}"
                                         Text="{Binding TakeProfitText, UpdateSourceTrigger=PropertyChanged}"
                                         Height="28" Width="70" MaxLength="10"
                                         ToolTip="Take Profit em USD"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="SL (USD)" Foreground="#90b5c9" FontSize="10" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource DerivTextBox}"
                                         Text="{Binding StopLossText, UpdateSourceTrigger=PropertyChanged}"
                                         Height="28" Width="70" MaxLength="10"
                                         ToolTip="Stop Loss em USD"/>
                            </StackPanel>
                            <StackPanel Grid.Column="6"
                                      Visibility="{Binding IsTrendMode, Converter={StaticResource InverseBoolToVis}}">
                                <TextBlock Text="Max." Foreground="#90b5c9" FontSize="10" Margin="0,0,0,4"/>
                                <TextBox Style="{StaticResource DerivTextBox}"
                                         Text="{Binding MaxContractsText, UpdateSourceTrigger=PropertyChanged}"
                                         Height="28" Width="70" MaxLength="2"
                                         ToolTip="Máximo de contratos simultâneos"/>
                            </StackPanel>
                        </Grid>

                        <!-- Recover -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Recover:" Foreground="#90b5c9" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox Style="{StaticResource DerivComboBox}"
                                      ItemsSource="{Binding RecoverModes}"
                                      SelectedItem="{Binding RecoverMode, Mode=TwoWay}"
                                      Width="100" Height="24"
                                      FontSize="10"
                                      Foreground="#00f0ff"
                                      ToolTip="Modo de recuperação (Martingale)"/>
                        </StackPanel>

                        <!-- Separator (hidden in Trend mode) -->
                        <Border Height="1" Background="#1d4957" Margin="0,0,0,10"
                                Visibility="{Binding IsTrendMode, Converter={StaticResource InverseBoolToVis}}"/>

                        <!-- Indicators (hidden in Trend mode) -->
                        <StackPanel Visibility="{Binding IsTrendMode, Converter={StaticResource InverseBoolToVis}}">
                            <TextBlock Text="Indicadores" Foreground="#90b5c9" FontSize="10" Margin="0,0,0,6"/>
                            <Grid Margin="0,0,0,10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Row="0" Grid.Column="0" Content="EMA 9/21" IsChecked="{Binding EnableEma}"
                                          Foreground="#a3b8cc" FontSize="11" Margin="0,0,12,4" Cursor="Hand"
                                          ToolTip="Cruzamento de médias EMA 9/21"/>
                                <CheckBox Grid.Row="0" Grid.Column="1" Content="RSI (14)" IsChecked="{Binding EnableRsi}"
                                          Foreground="#a3b8cc" FontSize="11" Margin="0,0,12,4" Cursor="Hand"
                                          ToolTip="Índice de Força Relativa (14 períodos)"/>
                                <CheckBox Grid.Row="0" Grid.Column="2" Content="S/R" IsChecked="{Binding EnableSupportResistance}"
                                          Foreground="#a3b8cc" FontSize="11" Margin="0,0,12,4" Cursor="Hand"
                                          ToolTip="Suporte e Resistência"/>
                                <CheckBox Grid.Row="0" Grid.Column="3" Content="MACD" IsChecked="{Binding EnableMacd}"
                                          Foreground="#a3b8cc" FontSize="11" Margin="0,0,12,4" Cursor="Hand"
                                          ToolTip="Moving Average Convergence Divergence"/>
                                <CheckBox Grid.Row="1" Grid.Column="0" Content="Bollinger" IsChecked="{Binding EnableBollinger}"
                                          Foreground="#a3b8cc" FontSize="11" Margin="0,0,12,4" Cursor="Hand"
                                          ToolTip="Bandas de Bollinger"/>
                                <CheckBox Grid.Row="1" Grid.Column="1" Content="Candles" IsChecked="{Binding EnableCandlePattern}"
                                          Foreground="#a3b8cc" FontSize="11" Margin="0,0,12,4" Cursor="Hand"
                                          ToolTip="Padrões de candlestick"/>
                                <CheckBox Grid.Row="1" Grid.Column="2" Content="Momentum" IsChecked="{Binding EnableMomentum}"
                                          Foreground="#a3b8cc" FontSize="11" Margin="0,0,12,4" Cursor="Hand"
                                          ToolTip="Indicador de momentum"/>
                            </Grid>

                            <!-- Confidence + Trailing -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                                        ToolTip="Confiança mínima para abrir posição">
                                <TextBlock Text="Confiança mín:" Foreground="#90b5c9" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Slider Width="120"
                                        Style="{StaticResource ConfidenceSliderStyle}"
                                        Value="{Binding ConfidenceThreshold}"
                                        VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ConfidenceThreshold, StringFormat=P0}"
                                           Foreground="#e0eef8" FontSize="11"
                                           FontFamily="Consolas" Margin="8,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <CheckBox Content="Trailing Stop (TP 70%→BE, 90%→50%)"
                                      IsChecked="{Binding EnableTrailingStop}"
                                      Foreground="#a3b8cc" FontSize="11" Margin="0,0,0,10" Cursor="Hand"
                                      ToolTip="Ajusta Stop Loss dinamicamente conforme lucro"/>
                        </StackPanel>

                        <!-- Separator -->
                        <Border Height="1" Background="#1d4957" Margin="0,0,0,10"/>

                        <!-- Status -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#4a6a7a"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="Fill" Value="#34c759"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                                <Setter Property="Fill" Value="#f0c040"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Foreground="#e0eef8" FontSize="11" VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Inativo"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="Text" Value="Ativo"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                                <Setter Property="Text" Value="Pausado"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Text="{Binding CurrentSignalText}"
                                   Foreground="#00e8c8" FontSize="11"
                                   FontFamily="Consolas" Margin="0,4,0,4"
                                   TextWrapping="Wrap" MaxWidth="300"
                                   Visibility="Collapsed"/>
                        <TextBlock Text="{Binding LastTradeText}"
                                   Foreground="#f0c040" FontSize="10"
                                   FontFamily="Consolas" Margin="0,0,0,4"
                                   TextWrapping="Wrap" MaxWidth="300"
                                   Visibility="Collapsed"/>
                        <TextBlock Text="{Binding StatsText}"
                                   Foreground="#e0eef8" FontSize="10"
                                   FontFamily="Consolas" Margin="0,0,0,10"
                                   Visibility="Collapsed"/>

                        <!-- Buttons -->
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding StartCommand}"
                                    Style="{StaticResource DerivCallButtonStyle}"
                                    Width="70" Margin="0,0,6,0"
                                    IsEnabled="{Binding IsRunning, Converter={StaticResource InverseBool}}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Path Data="M0,0 L8,5 L0,10 Z" Fill="White" Width="8" Height="10"
                                          Stretch="Uniform" Margin="0,0,4,0"/>
                                    <TextBlock Text="Iniciar" Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding PauseCommand}"
                                    Style="{StaticResource DerivToggleButtonStyle}"
                                    Width="70" Margin="0,0,6,0"
                                    IsEnabled="{Binding IsRunning}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Canvas Width="10" Height="11" Margin="0,0,4,0">
                                        <Rectangle Canvas.Left="0" Width="3.5" Height="11" RadiusX="1" RadiusY="1" Fill="White"/>
                                        <Rectangle Canvas.Left="5.5" Width="3.5" Height="11" RadiusX="1" RadiusY="1" Fill="White"/>
                                    </Canvas>
                                    <TextBlock Text="Pausar" Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Command="{Binding StopCommand}"
                                    Style="{StaticResource DerivPutButtonStyle}"
                                    Width="70"
                                    IsEnabled="{Binding IsRunning}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Rectangle Width="10" Height="10" RadiusX="2" RadiusY="2" Fill="White" Margin="0,0,4,0"/>
                                    <TextBlock Text="Parar" Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- BOT SIGNAL TEXTS (column 4, visible when bot active) -->
                <StackPanel Grid.Column="4" VerticalAlignment="Top" Margin="0,4,0,0"
                            DataContext="{Binding DataContext.Strategy, RelativeSource={RelativeSource AncestorType=Window}}">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsBotVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="{Binding CurrentSignalText}"
                               Foreground="#00e8c8" FontSize="11"
                               FontFamily="Consolas" Margin="0,0,0,4"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding LastTradeText}"
                               Foreground="#f0c040" FontSize="10"
                               FontFamily="Consolas" Margin="0,0,0,4"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding StatsText}"
                               Foreground="#e0eef8" FontSize="10"
                               FontFamily="Consolas" Margin="0,0,0,0"/>
                </StackPanel>

                <!-- RECOVER PANEL (visible when Recover active, spans cols 0-2) -->
                <StackPanel Grid.Column="0" Grid.ColumnSpan="3"
                            DataContext="{Binding DataContext.Recover, RelativeSource={RelativeSource AncestorType=Window}}">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRecoverVisible}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <!-- Mode selector -->
                    <TextBlock Text="Modo de Recuperação" Foreground="#90b5c9" FontSize="10" Margin="0,0,0,4"/>
                    <ComboBox Style="{StaticResource DerivComboBox}"
                              ItemsSource="{Binding RecoverModes}"
                              SelectedItem="{Binding SelectedMode, Mode=TwoWay}"
                              Height="28" Width="160"
                              HorizontalAlignment="Left"
                              FontSize="11"
                              Foreground="#00f0ff"
                              Margin="0,0,0,12"/>

                    <!-- Enable toggle -->
                    <CheckBox Content="Ativar Recuperação"
                              IsChecked="{Binding IsEnabled}"
                              Foreground="#a3b8cc" FontSize="11" Margin="0,0,0,12" Cursor="Hand"/>

                    <!-- Martingale fields -->
                    <StackPanel Visibility="{Binding IsMartingaleMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Stake (USD)" Foreground="#90b5c9" FontSize="10" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource DerivTextBox}"
                                 Text="{Binding StakeText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="30" Width="120"
                                 HorizontalAlignment="Left"
                                 MaxLength="10"
                                 PreviewTextInput="RecoverDecimalInput_PreviewTextInput"
                                 DataObject.Pasting="RecoverDecimalInput_Pasting"/>

                        <TextBlock Text="Fator (multiplicador)" Foreground="#90b5c9" FontSize="10" Margin="0,10,0,4"/>
                        <TextBox Style="{StaticResource DerivTextBox}"
                                 Text="{Binding FactorText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="30" Width="120"
                                 HorizontalAlignment="Left"
                                 MaxLength="10"
                                 PreviewTextInput="RecoverDecimalInput_PreviewTextInput"
                                 DataObject.Pasting="RecoverDecimalInput_Pasting"/>

                        <TextBlock Text="Nível (máximo)" Foreground="#90b5c9" FontSize="10" Margin="0,10,0,4"/>
                        <TextBox Style="{StaticResource DerivTextBox}"
                                 Text="{Binding MaxLevelText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="30" Width="120"
                                 HorizontalAlignment="Left"
                                 MaxLength="3"
                                 PreviewTextInput="RecoverIntegerInput_PreviewTextInput"
                                 DataObject.Pasting="RecoverIntegerInput_Pasting"/>

                        <TextBlock Text="Ao perder, stake × fator até nível máximo. Ao vencer ou atingir nível, reseta."
                                   Foreground="#6090a8" FontSize="9"
                                   TextWrapping="Wrap"
                                   Margin="0,12,0,0"/>
                    </StackPanel>

                    <!-- Deficit Recovery fields -->
                    <StackPanel Visibility="{Binding IsDeficitMode, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Stake Máxima (USD)" Foreground="#90b5c9" FontSize="10" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource DerivTextBox}"
                                 Text="{Binding DeficitMaxStakeText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="30" Width="120"
                                 HorizontalAlignment="Left"
                                 MaxLength="8"
                                 PreviewTextInput="RecoverDecimalInput_PreviewTextInput"
                                 DataObject.Pasting="RecoverDecimalInput_Pasting"/>

                        <TextBlock Text="Trades p/ Recuperar" Foreground="#90b5c9" FontSize="10" Margin="0,10,0,4"/>
                        <TextBox Style="{StaticResource DerivTextBox}"
                                 Text="{Binding DeficitRecoveryTradesText, UpdateSourceTrigger=PropertyChanged}"
                                 Height="30" Width="120"
                                 HorizontalAlignment="Left"
                                 MaxLength="2"
                                 PreviewTextInput="RecoverIntegerInput_PreviewTextInput"
                                 DataObject.Pasting="RecoverIntegerInput_Pasting"/>

                        <TextBlock Text="Calcula stake com base no déficit acumulado e payout médio dos últimos 5 trades. 1 = recuperar tudo no próximo trade."
                                   Foreground="#6090a8" FontSize="9"
                                   TextWrapping="Wrap"
                                   Margin="0,12,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- POSITIONS TABLE -->
                <controls:OpenPositionsView Grid.Column="4"
                                            DataContext="{Binding OpenPositions}"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
