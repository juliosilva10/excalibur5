<UserControl x:Class="Excalibur5.Views.Controls.HistoryPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="900">

    <Border CornerRadius="6"
            BorderBrush="#1d4957" BorderThickness="1"
            Margin="0,4,0,0">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0c1e2a" Offset="0"/>
                <GradientStop Color="#07121a" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="12,8,12,4">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Histórico" Foreground="#00f0ff" FontSize="12"
                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Text=" — Contratos" Foreground="#6090a8" FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                        Command="{Binding RefreshCommand}"
                        Cursor="Hand" ToolTip="Atualizar"
                        FocusVisualStyle="{x:Null}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="RefreshBorder" Padding="6,3" CornerRadius="4"
                                    Background="Transparent">
                                <TextBlock Text="⟳" Foreground="#6090a8" FontSize="14"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="RefreshBorder" Property="Background" Value="#1a3a4a"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- Loading indicator -->
            <TextBlock Grid.Row="1" Text="Carregando..."
                       Foreground="#6090a8" FontSize="11"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

            <!-- Data Grid -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Trades}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#1d4957"
                      BorderThickness="0"
                      Background="Transparent"
                      RowBackground="#0c1e2a"
                      AlternatingRowBackground="#0f2535"
                      Foreground="#e0eef8"
                      FontSize="11"
                      FontFamily="Consolas"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      Margin="8,4,8,8">
                <DataGrid.Style>
                    <Style TargetType="DataGrid">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Style>
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#112935"/>
                        <Setter Property="Foreground" Value="#00f0ff"/>
                        <Setter Property="FontSize" Value="10"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="BorderBrush" Value="#1d4957"/>
                        <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="6,3"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#1a3f52"/>
                                <Setter Property="Foreground" Value="#e0eef8"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#153342"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Operação" Binding="{Binding Operacao}" Width="1*"/>
                    <DataGridTextColumn Header="Estratégia" Binding="{Binding Estrategia}" Width="1.2*"/>
                    <DataGridTextColumn Header="Tipo" Binding="{Binding Tipo}" Width="1.5*"/>
                    <DataGridTextColumn Header="Nº Ref." Binding="{Binding ReferenceNumber}" Width="1.4*"/>
                    <DataGridTextColumn Header="Compra" Binding="{Binding PurchaseTime, StringFormat=dd/MM HH:mm:ss}" Width="1.6*"/>
                    <DataGridTextColumn Header="Stake" Binding="{Binding Stake, StringFormat=F2}" Width="1*"/>
                    <DataGridTextColumn Header="Venda" Binding="{Binding SellTime, StringFormat=dd/MM HH:mm:ss}" Width="1.6*"/>
                    <DataGridTextColumn Header="Entry Spot" Binding="{Binding EntrySpot}" Width="1.3*"/>
                    <DataGridTextColumn Header="Exit Spot" Binding="{Binding ExitSpot}" Width="1.3*"/>
                    <DataGridTextColumn Header="Valor" Binding="{Binding ContractValue, StringFormat=F2}" Width="1*"/>
                    <DataGridTextColumn Header="Lucro/Perda" Binding="{Binding ProfitLoss, StringFormat=F2}" Width="1.2*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Border>
</UserControl>
