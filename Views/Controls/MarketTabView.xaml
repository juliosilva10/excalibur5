<UserControl x:Class="Excalibur5.Views.Controls.MarketTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:Excalibur5.Converters"
             xmlns:controls="clr-namespace:Excalibur5.Views.Controls"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="700">

    <UserControl.Resources>
        <converters:TickDirectionToColorConverter x:Key="DirToColor"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="200"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Current tick value -->
        <Border Grid.Row="0" Margin="0,0,0,4" Padding="12,10">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#0f2030" Offset="0"/>
                    <GradientStop Color="#0a1821" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding TickVariation}"
                           Foreground="{Binding CurrentDirection, Converter={StaticResource DirToColor}}"
                           FontFamily="Consolas"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="0,0,16,0"/>
                <TextBlock Text="{Binding CurrentQuote}"
                           FontFamily="Consolas"
                           FontSize="20"
                           Foreground="{Binding CurrentDirection, Converter={StaticResource DirToColor}}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Chart + Tick list -->
        <Grid Grid.Row="1"
              Visibility="{Binding IsChartReady, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="140"/>
            </Grid.ColumnDefinitions>

            <!-- Chart area -->
            <Border Grid.Column="0" Margin="0,0,4,0"
                    CornerRadius="6"
                    BorderBrush="#1d4957" BorderThickness="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0a1821" Offset="0"/>
                        <GradientStop Color="#07121a" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Main chart canvas -->
                    <Canvas x:Name="ChartCanvas" Grid.Column="0" Grid.Row="0"
                            ClipToBounds="True"
                            MouseWheel="ChartCanvas_MouseWheel"
                            MouseMove="ChartCanvas_MouseMove"
                            MouseLeave="ChartCanvas_MouseLeave"
                            MouseLeftButtonDown="ChartCanvas_MouseLeftButtonDown"
                            Background="Transparent"/>

                    <!-- Y axis (values) -->
                    <Canvas x:Name="YAxisCanvas" Grid.Column="1" Grid.Row="0"
                            Width="52" ClipToBounds="True"/>

                    <!-- X axis (time) -->
                    <Canvas x:Name="XAxisCanvas" Grid.Column="0" Grid.Row="1"
                            Height="16" ClipToBounds="True"/>
                </Grid>
            </Border>

            <!-- Tick stream list -->
            <Border Grid.Column="1"
                    CornerRadius="6"
                    BorderBrush="#1d4957" BorderThickness="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#0c1e2a" Offset="0"/>
                        <GradientStop Color="#07121a" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Ticks Stream"
                               Foreground="#e0eef8" FontSize="10"
                               Margin="8,6,0,4"/>

                    <ItemsControl Grid.Row="1"
                                  ItemsSource="{Binding RecentTicks}"
                                  VirtualizingStackPanel.IsVirtualizing="True"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ItemsControl.Template>
                            <ControlTemplate TargetType="ItemsControl">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ScrollViewer.Resources>
                                        <Style TargetType="ScrollBar">
                                            <Setter Property="OverridesDefaultStyle" Value="True"/>
                                            <Setter Property="Width" Value="8"/>
                                            <Setter Property="MinWidth" Value="8"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ScrollBar">
                                                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                                                            <Track.Thumb>
                                                                <Thumb Style="{StaticResource SlimScrollBarThumb}"/>
                                                            </Track.Thumb>
                                                        </Track>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ScrollViewer.Resources>
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </ControlTemplate>
                        </ItemsControl.Template>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding QuoteRaw}"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           Margin="8,1,4,1"
                                           Foreground="{Binding Direction, Converter={StaticResource DirToColor}}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>

        <!-- Contracts panel -->
        <controls:ContractPanelView Grid.Row="2" DataContext="{Binding ContractPanel}"/>
    </Grid>
</UserControl>
