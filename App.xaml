<Application x:Class="Excalibur5.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:Excalibur5.Converters">
    <Application.Resources>

        <!-- Paleta Deriv (baseada no Excalibur3.1) -->
        <Color x:Key="DerivBgColor">#07121a</Color>
        <Color x:Key="DerivCardBg">#153342</Color>
        <Color x:Key="DerivCardBorder">#1d4957</Color>
        <Color x:Key="DerivInputBg">#153342</Color>
        <Color x:Key="DerivInputBorder">#1d4957</Color>
        <Color x:Key="DerivTextColor">#a3b8cc</Color>
        <Color x:Key="DerivValueColor">#f3fbff</Color>

        <SolidColorBrush x:Key="BackgroundBrush"      Color="#07121a"/>
        <SolidColorBrush x:Key="SurfaceBrush"         Color="#0f2030"/>
        <SolidColorBrush x:Key="Surface2Brush"        Color="#153342"/>
        <SolidColorBrush x:Key="AccentBrush"          Color="#00f0ff"/>
        <SolidColorBrush x:Key="TextBrush"            Color="#f3fbff"/>
        <SolidColorBrush x:Key="SubtleBrush"          Color="#a3b8cc"/>
        <SolidColorBrush x:Key="BorderBrush"          Color="#1d4957"/>
        <SolidColorBrush x:Key="SuccessBrush"         Color="#34c759"/>
        <SolidColorBrush x:Key="RealBadgeBrush"       Color="#1a4a28"/>
        <SolidColorBrush x:Key="VirtualBadgeBrush"    Color="#1a3a6b"/>
        <SolidColorBrush x:Key="DerivCardBgBrush"     Color="#153342"/>
        <SolidColorBrush x:Key="DerivCardBorderBrush" Color="#1d4957"/>

        <!-- Converters -->
        <converters:InverseBoolConverter x:Key="InverseBool"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <converters:TickDirectionToColorConverter x:Key="DirToColor"/>
        <BooleanToVisibilityConverter   x:Key="BoolToVis"/>

        <!-- RadioButton style: carved radial effect with cyan dot -->
        <Style TargetType="RadioButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Foreground" Value="#a3b8cc"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Outer ring with carved/inset effect -->
                            <Border x:Name="OuterBorder"
                                    Width="16" Height="16"
                                    CornerRadius="8"
                                    BorderThickness="1.5"
                                    BorderBrush="#1d4957">
                                <Border.Background>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#08141a" Offset="0.0"/>
                                        <GradientStop Color="#0d1f28" Offset="0.5"/>
                                        <GradientStop Color="#153342" Offset="1.0"/>
                                    </RadialGradientBrush>
                                </Border.Background>
                                <!-- Inner dot -->
                                <Ellipse x:Name="CheckDot"
                                         Width="8" Height="8"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"
                                         Opacity="0">
                                    <Ellipse.Fill>
                                        <RadialGradientBrush>
                                            <GradientStop Color="#00f0ff" Offset="0.0"/>
                                            <GradientStop Color="#009db3" Offset="1.0"/>
                                        </RadialGradientBrush>
                                    </Ellipse.Fill>
                                </Ellipse>
                            </Border>
                            <ContentPresenter Margin="6,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckDot" Property="Opacity" Value="1"/>
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#00f0ff"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#00f0ff"/>
                                <Setter TargetName="OuterBorder" Property="Background">
                                    <Setter.Value>
                                        <RadialGradientBrush>
                                            <GradientStop Color="#0a1a24" Offset="0.0"/>
                                            <GradientStop Color="#10283a" Offset="0.5"/>
                                            <GradientStop Color="#1a3f52" Offset="1.0"/>
                                        </RadialGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DayTitleTemplate: weekday header labels for Calendar -->
        <DataTemplate x:Key="DayTitleTemplate">
            <TextBlock Text="{Binding}"
                       Foreground="#00f0ff"
                       FontSize="10"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,4,0,2"/>
        </DataTemplate>

        <!-- Window style -->
        <Style TargetType="Window">
            <Setter Property="Background"  Value="{StaticResource BackgroundBrush}"/>
            <Setter Property="Foreground"  Value="{StaticResource TextBrush}"/>
            <Setter Property="FontFamily"  Value="Segoe UI"/>
            <Setter Property="FontSize"    Value="13"/>
        </Style>

        <!-- Tooltip style -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#0f2030"/>
            <Setter Property="Foreground" Value="#e0eef8"/>
            <Setter Property="BorderBrush" Value="#1d4957"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Thin rounded scrollbar - only visible on ScrollViewer hover -->
        <Style x:Key="SlimScrollBarThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                CornerRadius="3"
                                Background="#60a0b8c8"
                                Margin="1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder" Property="Background" Value="#9000f0ff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="MinWidth" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource SlimScrollBarThumb}"/>
                            </Track.Thumb>
                        </Track>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="6"/>
                    <Setter Property="MinHeight" Value="6"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Track x:Name="PART_Track" IsDirectionReversed="False">
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource SlimScrollBarThumb}"/>
                                    </Track.Thumb>
                                </Track>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <ScrollContentPresenter/>
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                       HorizontalAlignment="Right"
                                       Orientation="Vertical"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                       Opacity="0"/>
                            <ScrollBar x:Name="PART_HorizontalScrollBar"
                                       VerticalAlignment="Bottom"
                                       Orientation="Horizontal"
                                       Maximum="{TemplateBinding ScrollableWidth}"
                                       ViewportSize="{TemplateBinding ViewportWidth}"
                                       Value="{TemplateBinding HorizontalOffset}"
                                       Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                                       Opacity="0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PART_VerticalScrollBar"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="PART_HorizontalScrollBar"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PART_VerticalScrollBar"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.4"/>
                                            <DoubleAnimation Storyboard.TargetName="PART_HorizontalScrollBar"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.4"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Call Button Style (green, same structure as DerivToggleButtonStyle) -->
        <Style x:Key="DerivCallButtonStyle" TargetType="Button">
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="Foreground"    Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"       Value="10,0,10,0"/>
            <Setter Property="FontSize"      Value="11"/>
            <Setter Property="Height"        Value="30"/>
            <Setter Property="Width"         Value="70"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="GlowBorder"
                                    CornerRadius="8"
                                    Background="#34c759"
                                    Opacity="0.22">
                                <Border.Effect>
                                    <BlurEffect Radius="20"/>
                                </Border.Effect>
                            </Border>
                            <Border x:Name="ShadowBorder"
                                    CornerRadius="8"
                                    Background="Black"
                                    Opacity="0.4"
                                    Margin="0,2,0,-2"/>
                            <Border x:Name="MainBorder"
                                    CornerRadius="8"
                                    BorderThickness="1.5"
                                    BorderBrush="#5ec97b">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#2d6e48" Offset="0.0"/>
                                        <GradientStop Color="#235c3d" Offset="0.4"/>
                                        <GradientStop Color="#18422d" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid>
                                    <Border CornerRadius="7,7,0,0" Height="8" VerticalAlignment="Top" Opacity="0.10"
                                            IsHitTestVisible="False">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="White" Offset="0.0"/>
                                                <GradientStop Color="Transparent" Offset="1.0"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="GlowBorder" Property="Opacity" Value="0.58"/>
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#9bfbb6"/>
                                <Setter TargetName="MainBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#3d8b5e" Offset="0.0"/>
                                            <GradientStop Color="#2b6b48" Offset="0.45"/>
                                            <GradientStop Color="#1a472f" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ShadowBorder" Property="Opacity" Value="0.1"/>
                                <Setter TargetName="GlowBorder"   Property="Opacity" Value="0.7"/>
                                <Setter TargetName="MainBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#235c3d" Offset="0.0"/>
                                            <GradientStop Color="#1c4b33" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="MainBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Put Button Style (red, same structure as DerivToggleButtonStyle) -->
        <Style x:Key="DerivPutButtonStyle" TargetType="Button">
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="Foreground"    Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"       Value="10,0,10,0"/>
            <Setter Property="FontSize"      Value="11"/>
            <Setter Property="Height"        Value="30"/>
            <Setter Property="Width"         Value="70"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="GlowBorder"
                                    CornerRadius="8"
                                    Background="#FF6B6B"
                                    Opacity="0.22">
                                <Border.Effect>
                                    <BlurEffect Radius="20"/>
                                </Border.Effect>
                            </Border>
                            <Border x:Name="ShadowBorder"
                                    CornerRadius="8"
                                    Background="Black"
                                    Opacity="0.4"
                                    Margin="0,2,0,-2"/>
                            <Border x:Name="MainBorder"
                                    CornerRadius="8"
                                    BorderThickness="1.5"
                                    BorderBrush="#e07070">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#6e2d2d" Offset="0.0"/>
                                        <GradientStop Color="#5c2323" Offset="0.4"/>
                                        <GradientStop Color="#421818" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Grid>
                                    <Border CornerRadius="7,7,0,0" Height="8" VerticalAlignment="Top" Opacity="0.10"
                                            IsHitTestVisible="False">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="White" Offset="0.0"/>
                                                <GradientStop Color="Transparent" Offset="1.0"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Margin="{TemplateBinding Padding}"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="GlowBorder" Property="Opacity" Value="0.58"/>
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#ffaaaa"/>
                                <Setter TargetName="MainBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#8b3d3d" Offset="0.0"/>
                                            <GradientStop Color="#6b2b2b" Offset="0.45"/>
                                            <GradientStop Color="#471a1a" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ShadowBorder" Property="Opacity" Value="0.1"/>
                                <Setter TargetName="GlowBorder"   Property="Opacity" Value="0.7"/>
                                <Setter TargetName="MainBorder" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#5c2323" Offset="0.0"/>
                                            <GradientStop Color="#4b1c1c" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="MainBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DerivTextBox: sunken input style (same as TokenPasswordBox but for TextBox) -->
        <Style x:Key="DerivTextBox" TargetType="TextBox">
            <Setter Property="Background"   Value="{StaticResource DerivCardBgBrush}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"  Value="{StaticResource DerivCardBorderBrush}"/>
            <Setter Property="Padding"      Value="8,4,8,4"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="FontFamily"   Value="Consolas"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush"   Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid>
                            <Border x:Name="GlowBorder"
                                    CornerRadius="8"
                                    Background="Transparent"
                                    BorderBrush="#00f0ff"
                                    BorderThickness="2"
                                    Opacity="0">
                                <Border.Effect>
                                    <DropShadowEffect Color="#00f0ff" BlurRadius="18" ShadowDepth="0" Opacity="1"/>
                                </Border.Effect>
                                <Border.Margin>
                                    <Thickness>-2,-2,-2,-2</Thickness>
                                </Border.Margin>
                            </Border>
                            <Border x:Name="MainBorder"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    CornerRadius="8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#08141a" Offset="0.0"/>
                                        <GradientStop Color="#0d1f28" Offset="0.1"/>
                                        <GradientStop Color="#153342" Offset="0.5"/>
                                        <GradientStop Color="#153342" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="GlowBorder"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.3"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="GlowBorder"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0" Duration="0:0:0.3"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="GlowBorder" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#66ffffff"/>
                                <Setter TargetName="MainBorder" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CalendarItem: the main container inside Calendar (header + grid) -->
        <Style TargetType="Primitives:CalendarItem"
               xmlns:Primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
            <Style.Resources>
                <DataTemplate x:Key="DayTitleTemplate">
                    <TextBlock Text="{Binding}"
                               Foreground="#00f0ff"
                               FontSize="10"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="0,4,0,2"/>
                </DataTemplate>
            </Style.Resources>
            <Setter Property="Background" Value="#0f2030"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Primitives:CalendarItem"
                                     xmlns:Primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">
                        <ControlTemplate.Resources>
                            <DataTemplate x:Key="DayTitleTemplate">
                                <TextBlock Text="{Binding}"
                                           Foreground="#00f0ff"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="0,4,0,2"/>
                            </DataTemplate>
                        </ControlTemplate.Resources>
                        <Border Background="#0f2030"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="6">
                            <Grid TextElement.Foreground="#00f0ff">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <!-- Header: prev/next buttons + month/year -->
                                <Grid Grid.Row="0" Margin="4,4,4,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="PART_PreviousButton" Grid.Column="0"
                                            Focusable="False" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="Transparent" Padding="6,4">
                                                    <Path Data="M8,0 L0,5 L8,10" Stroke="#00f0ff"
                                                          StrokeThickness="1.5" Width="8" Height="10"
                                                          Stretch="Uniform"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button x:Name="PART_HeaderButton" Grid.Column="1"
                                            Focusable="False" Cursor="Hand"
                                            HorizontalAlignment="Center">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="Transparent" Padding="4,2">
                                                    <ContentPresenter
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Button.Foreground>
                                            <SolidColorBrush Color="#00f0ff"/>
                                        </Button.Foreground>
                                    </Button>
                                    <Button x:Name="PART_NextButton" Grid.Column="2"
                                            Focusable="False" Cursor="Hand">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="Transparent" Padding="6,4">
                                                    <Path Data="M0,0 L8,5 L0,10" Stroke="#00f0ff"
                                                          StrokeThickness="1.5" Width="8" Height="10"
                                                          Stretch="Uniform"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                                <!-- Day grid -->
                                <Grid x:Name="PART_MonthView" Grid.Row="1"
                                      Margin="4,0,4,4" Visibility="Visible">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                </Grid>
                                <!-- Year/month grid -->
                                <Grid x:Name="PART_YearView" Grid.Row="1"
                                      Margin="4,0,4,4" Visibility="Hidden">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                </Grid>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CalendarDayButton: light text on dark background -->
        <Style TargetType="CalendarDayButton">
            <Setter Property="Foreground" Value="#00f0ff"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="MinWidth" Value="28"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CalendarDayButton">
                        <Grid>
                            <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="4"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsToday" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1d4957"/>
                                <Setter Property="Foreground" Value="#00f0ff"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#00f0ff"/>
                                <Setter Property="Foreground" Value="#07121a"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1a4a5e"/>
                            </Trigger>
                            <Trigger Property="IsBlackedOut" Value="True">
                                <Setter Property="Foreground" Value="#405060"/>
                                <Setter TargetName="Bg" Property="Background" Value="Transparent"/>
                                <Setter Property="IsHitTestVisible" Value="False"/>
                            </Trigger>
                            <Trigger Property="IsInactive" Value="True">
                                <Setter Property="Foreground" Value="#506878"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CalendarButton (month/year view cells) -->
        <Style TargetType="CalendarButton">
            <Setter Property="Foreground" Value="#00f0ff"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CalendarButton">
                        <Grid>
                            <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="4"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1a4a5e"/>
                            </Trigger>
                            <Trigger Property="HasSelectedDays" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#1d4957"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DerivCalendarStyle: dark-themed Calendar popup -->
        <Style x:Key="DerivCalendarStyle" TargetType="Calendar">
            <Setter Property="Background" Value="#0f2030"/>
            <Setter Property="Foreground" Value="#00f0ff"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CalendarDayButtonStyle" Value="{StaticResource {x:Type CalendarDayButton}}"/>
            <Setter Property="CalendarButtonStyle" Value="{StaticResource {x:Type CalendarButton}}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Calendar">
                        <Border Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Padding="0">
                            <CalendarItem x:Name="PART_CalendarItem"
                                          Background="#0f2030"
                                          BorderBrush="Transparent"
                                          BorderThickness="0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DatePickerTextBox: suppress default white border/background -->
        <Style TargetType="DatePickerTextBox">
            <Setter Property="Foreground" Value="#f3fbff"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="SelectionBrush" Value="Transparent"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePickerTextBox">
                        <Grid Background="Transparent">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="WatermarkStates">
                                    <VisualState x:Name="Unwatermarked"/>
                                    <VisualState x:Name="Watermarked">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="WatermarkContent"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0"/>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentControl x:Name="WatermarkContent"
                                            Opacity="0"
                                            Foreground="#6090a8"
                                            IsHitTestVisible="False"
                                            VerticalAlignment="Center"/>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"
                                          Background="Transparent"
                                          VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DerivDatePicker: dark-themed DatePicker with rounded corners -->
        <Style x:Key="DerivDatePicker" TargetType="DatePicker">
            <Setter Property="Background" Value="#153342"/>
            <Setter Property="Foreground" Value="#f3fbff"/>
            <Setter Property="BorderBrush" Value="#1d4957"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Width" Value="160"/>
            <Setter Property="CalendarStyle" Value="{StaticResource DerivCalendarStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Border x:Name="Border"
                                CornerRadius="8"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#08141a" Offset="0.0"/>
                                    <GradientStop Color="#153342" Offset="0.5"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <DatePickerTextBox x:Name="PART_TextBox"
                                                   Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   Focusable="{TemplateBinding Focusable}"/>
                                <Button x:Name="PART_Button"
                                        Grid.Column="1"
                                        Cursor="Hand"
                                        Width="20" Height="20"
                                        VerticalAlignment="Center"
                                        Focusable="False">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent">
                                                <Path x:Name="Icon"
                                                      Data="M0,0 L8,0 L8,8 L0,8 Z M0,2 L8,2 M2,0 L2,1 M6,0 L6,1"
                                                      Stroke="#00f0ff" StrokeThickness="1"
                                                      Width="10" Height="10"
                                                      Stretch="Uniform"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Icon" Property="Stroke" Value="#80ffff"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Placement="Bottom"
                                       PlacementTarget="{Binding ElementName=Border}"
                                       StaysOpen="False"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="#00f0ff"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DerivComboBox: dark-themed ComboBox with rounded corners -->
        <Style x:Key="DerivComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#153342"/>
            <Setter Property="Foreground" Value="#f3fbff"/>
            <Setter Property="BorderBrush" Value="#1d4957"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Width" Value="160"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border"
                                                CornerRadius="8"
                                                BorderBrush="#1d4957"
                                                BorderThickness="1">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#08141a" Offset="0.0"/>
                                                    <GradientStop Color="#153342" Offset="0.5"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <Path Grid.Column="1"
                                                      Data="M0,0 L4,4 L8,0"
                                                      Stroke="#00f0ff" StrokeThickness="1.5"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Width="8" Height="5"
                                                      Stretch="Uniform"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#00f0ff"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="8,4,24,4"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                      SnapsToDevicePixels="True">
                                    <Border x:Name="DropDownBorder"
                                            CornerRadius="6"
                                            Background="#0f2030"
                                            BorderBrush="#1d4957"
                                            BorderThickness="1"
                                            Margin="0,2,0,0"/>
                                    <ScrollViewer Margin="4,6,4,6"
                                                  SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#f3fbff"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Setter Property="FontFamily" Value="Consolas"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}"
                                            CornerRadius="4">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#1a4a5e"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#1d4957"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
